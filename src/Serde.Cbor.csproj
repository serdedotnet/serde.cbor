<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>CBOR (RFC 8949) serialization and deserialization for .NET, built on the Serde framework.</Description>
    <Authors>serdedotnet</Authors>
    <PackageProjectUrl>https://github.com/serdedotnet/serde.cbor</PackageProjectUrl>
    <RepositoryUrl>https://github.com/serdedotnet/serde.cbor</RepositoryUrl>
    <PackageTags>cbor;serde;serialization</PackageTags>
    <PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Serde" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
